{
  "name": "co2-calculator",
  "version": "0.0.6",
  "description": "co2-calculator",
  "productName": "EPFL CO2 Calculator",
  "author": "Guilbert Pierre <pierre.guilbert@epfl.ch>",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,css,html,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,ts,vue,scss,css,html,md,json}\" --ignore-path .gitignore",
    "test": "npm run test-ct && npm run test:e2e",
    "test:e2e": "playwright test tests/integration",
    "test:e2e:headed": "playwright test tests/integration --headed",
    "test:e2e:report": "playwright show-report",
    "test-ct": "playwright test -c playwright-ct.config.ts",
    "dev": "quasar dev",
    "preview": "npx vite preview --outDir dist/spa",
    "build": "quasar build",
    "postinstall": "quasar prepare",
    "mock:auth": "node src/mock/mockauth.js",
    "gen-api-types": "node scripts/gen-api-types.mjs"
  },
  "dependencies": {
    "@quasar/extras": "=1.18.0",
    "echarts": "=6.1.0",
    "ky": "=1.14.0",
    "maplibre-gl": "=5.24.0",
    "pinia": "=3.0.4",
    "pinia-plugin-persistedstate": "=4.7.1",
    "quasar": "=2.20.1",
    "unwrapped": "=0.1.25",
    "vue": "=3.5.38",
    "vue-echarts": "=8.0.1",
    "vue-i18n": "=11.4.6",
    "vue-router": "=4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "=10.0.1",
    "@intlify/unplugin-vue-i18n": "=11.2.4",
    "@playwright/experimental-ct-vue": "=1.61.1",
    "@playwright/test": "=1.61.0",
    "@quasar/app-vite": "=2.6.2",
    "@types/node": "=24.13.2",
    "@vue/eslint-config-typescript": "=14.9.0",
    "autoprefixer": "=10.5.0",
    "chokidar": "=4.0.3",
    "eslint": "=10.5.0",
    "eslint-config-prettier": "=10.1.8",
    "eslint-plugin-vue": "=10.9.2",
    "globals": "=17.7.0",
    "openapi-typescript": "=7.13.0",
    "postcss-html": "=1.8.1",
    "postcss-rtlcss": "=5.7.1",
    "prettier": "=3.8.4",
    "sass": "=1.101.0",
    "stylelint": "=17.13.0",
    "stylelint-config-recommended-vue": "=1.6.1",
    "stylelint-config-standard-scss": "=17.0.0",
    "stylelint-scss": "=7.2.0",
    "typescript": "=5.9.3",
    "typescript-eslint": "^8.62.0",
    "vue-eslint-parser": "=10.4.1",
    "vue-tsc": "=3.3.5"
  },
  "overrides": {
    "esbuild": "=0.28.1",
    "minimatch": "=10.2.4",
    "serialize-javascript": "=7.0.5",
    "vue-i18n": "$vue-i18n",
    "js-yaml": "=4.2.0"
  },
  "type": "module",
  "packageManager": "npm@11.14.1",
  "engines": {
    "node": ">=v24.15.0 <25",
    "npm": ">=11.12.1 <12"
  }
}
