{
  "name": "co2-calculator",
  "version": "0.0.6",
  "description": "co2-calculator",
  "productName": "EPFL CO2 Calculator",
  "author": "Guilbert Pierre <pierre.guilbert@epfl.ch>",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,css,html,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,ts,vue,scss,css,html,md,json}\" --ignore-path .gitignore",
    "test": "npm run test-ct && npm run test:e2e",
    "test:e2e": "playwright test tests/integration",
    "test:e2e:headed": "playwright test tests/integration --headed",
    "test:e2e:report": "playwright show-report",
    "test-ct": "playwright test -c playwright-ct.config.ts",
    "dev": "quasar dev",
    "preview": "npx vite preview --outDir dist/spa",
    "build": "quasar build",
    "postinstall": "quasar prepare",
    "mock:auth": "node src/mock/mockauth.js",
    "storybook": "storybook dev -p 6006 --config-dir storybook/.storybook",
    "storybook:build": "storybook build --config-dir storybook/.storybook",
    "storybook:test": "test-storybook --config-dir storybook/.storybook",
    "storybook:test-ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npm run storybook -- --no-open --quiet --ci\" \"wait-on tcp:127.0.0.1:6006 && npm run storybook:test\""
  },
  "dependencies": {
    "@quasar/extras": "=1.17.0",
    "echarts": "^6.0.0",
    "ky": "=1.14.0",
    "pinia": "=3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "quasar": "=2.18.5",
    "unwrapped": "^0.1.25",
    "vue": "=3.5.30",
    "vue-echarts": "=8.0.1",
    "vue-i18n": "=11.3.0",
    "vue-router": "=4.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intlify/unplugin-vue-i18n": "=11.1.1",
    "@playwright/experimental-ct-vue": "1.58.2",
    "@playwright/test": "1.58.2",
    "@quasar/app-vite": "=2.5.4",
    "@storybook/addon-a11y": "=10.2.15",
    "@storybook/addon-docs": "=10.2.17",
    "@storybook/test-runner": "=0.24.2",
    "@storybook/vue3-vite": "=10.2.15",
    "@types/node": "=24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.4.2",
    "chokidar": "^4.0.3",
    "concurrently": "=9.2.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "=10.1.8",
    "eslint-plugin-storybook": "=10.3.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "postcss-html": "^1.8.0",
    "postcss-rtlcss": "^5.7.0",
    "prettier": "=3.8.1",
    "sass": "^1.93.3",
    "storybook": "=10.2.19",
    "stylelint": "^17.3.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.1.3",
    "wait-on": "=9.0.4"
  },
  "overrides": {
    "minimatch": "^10.2.4",
    "serialize-javascript": "^7.0.4"
  },
  "type": "module",
  "engines": {
    "node": ">=24",
    "npm": ">= 6.13.4"
  }
}
