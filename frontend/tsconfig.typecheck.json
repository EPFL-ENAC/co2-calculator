{
  "extends": "./tsconfig.json",
  "include": ["src/**/*", "tests/**/*"],
  "skipLibCheck": true,
  "exclude": [
    "**/*.css",
    "**/*.scss",
    "**/*.sass",
    "**/*.less",
    "src/css",
    "src/assets",
    "**/*.stories.ts",
    "**/*.stories.tsx"
  ],

  "compilerOptions": {
    "incremental": true
  }
}
