{
  "ci": {
    "collect": {
      "startServerCommand": "npx serve -s frontend/dist/spa -l 8080",
      "startServerReadyPattern": "Accepting connections",
      "url": [
        "http://localhost:8080/en/login",
        "http://localhost:8080/en/login-test",
        "http://localhost:8080/en/workspace-setup",
        "http://localhost:8080/en/MOCK/2024/home",
        "http://localhost:8080/en/MOCK/2024/simulations",
        "http://localhost:8080/en/MOCK/2024/simulations/add",
        "http://localhost:8080/en/MOCK/2024/simulations/edit/abc123",
        "http://localhost:8080/en/MOCK/2024/documentation",
        "http://localhost:8080/en/MOCK/2024/headcount",
        "http://localhost:8080/en/MOCK/2024/buildings",
        "http://localhost:8080/en/MOCK/2024/purchases",
        "http://localhost:8080/en/MOCK/2024/external-cloud-and-ai",
        "http://localhost:8080/en/MOCK/2024/research-facilities",
        "http://localhost:8080/en/MOCK/2024/process-emissions",
        "http://localhost:8080/en/MOCK/2024/professional-travel",
        "http://localhost:8080/en/MOCK/2024/equipment-electric-consumption",
        "http://localhost:8080/en/back-office/reporting",
        "http://localhost:8080/en/back-office/user-management",
        "http://localhost:8080/en/back-office/data-management",
        "http://localhost:8080/en/back-office/documentation-editing",
        "http://localhost:8080/en/back-office/ui-texts-editing",
        "http://localhost:8080/en/back-office/logs",
        "http://localhost:8080/en/back-office/documentation",
        "http://localhost:8080/unauthorized"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "plugins": ["lighthouse-plugin-ecoindex-core"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.8
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.7
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.9
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
